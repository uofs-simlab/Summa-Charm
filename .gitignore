# Build artifacts - ignore build outputs but allow source files
build/**/cmake_build/
build/**/*.o
build/**/*.so
build/**/*.a
build/**/*.mod
build/**/*.exe
*.o
*.so
*.a
*.mod
*.exe

# Allow source files in build directory
!build/includes/
!build/source/
!build/CMakeLists.txt
!build/cmake/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# Charm++ generated files
*.decl.h
*.def.h
charmrun
*.sts
*.sum
*.log

# Fortran modules and objects
*.mod
*.smod

# Output files
out.txt
*.out
*.nc
*.txt
logs/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Backup files
*.bak
*.backup

# Documentation build
docs/_build/
docs/html/
docs/latex/

# Python cache (if any Python scripts)
__pycache__/
*.pyc
*.pyo

# Editor files
*.vim
*.emacs

# Log files
*.log
logs/

# Data files (typically large)
*.dat
*.bin
data/

# Configuration files with sensitive information
config_local.json
settings_local.json
