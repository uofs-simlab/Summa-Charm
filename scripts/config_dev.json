{
  "Distributed_Settings": {
    "distributed_mode": false,
    "port": 8080,
    "total_hru_count": 1000,
    "num_hru_per_batch": 100,
    "load_balancing": true,
    "num_nodes": 1,
    "servers_list": [
      {"hostname": "localhost"}
    ]
  },
  "Summa_Actor": {
    "max_gru_per_job": 1000,
    "enable_logging": true,
    "log_dir": "./logs"
  },
  "File_Access_Actor": {
    "num_partitions_in_output_buffer": 8,
    "num_timesteps_in_output_buffer": 500,
    "output_file_suffix": "_charm"
  },
  "Job_Actor": {
    "file_manager_path": "./scripts/fileManager.txt",
    "settings_path": "./summa/settings",
    "output_path": "./output",
    "forcing_path": "./forcing"
  },
  "HRU_Actor": {
    "print_output": true,
    "output_frequency": 100,
    "abs_tol": 1e-6,
    "rel_tol": 1e-4
  }
}
